<%= form_with(model: @course, local: true) do |form| %>

  <% if @course.errors.any? %>
    <div class="alert alert-danger">
      <h5><%= pluralize(@course.errors.count, "error") %> prevented this course from being saved:</h5>

      <ul>
        <% @course.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= form.label :course_code, class: "form-label" %>
    <%= form.text_field :course_code, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= form.label :course_name, class: "form-label" %>
    <%= form.text_field :course_name, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= form.label :duration, class: "form-label" %>
    <%= form.text_field :duration, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= form.label :fees, class: "form-label" %>
    <%= form.number_field :fees, step: 0.01, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= form.label :total_seats %>
    <%= form.number_field :total_seats, class: "form-control", placeholder: "Enter Total Seats" %>

  </div>

<%= form.submit(
      @course.new_record? ? "Create Course" : "Update Course",
      class: "btn btn-success"
    ) %>
  <%= link_to "Back", courses_path, class: "btn btn-secondary" %>

<% end %>