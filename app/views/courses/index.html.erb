<div class="py-4">
  <div class="page-header">

      <div>
          <h1>Course Management</h1>
          <p>
              Manage all academic programs.
          </p>
      </div>

      <%= link_to new_course_path,
          class: "btn btn-primary add-course-btn" do %>

          <i class="bi bi-plus-circle"></i>

          Add Course

      <% end %>

  </div>


  <div class="course-stats">

    <div class="stat-card">

        <small>Total Courses</small>

        <h2>
            <%= @courses.count %>
        </h2>

    </div>

    <div class="stat-card">

        <small>Total Students</small>

        <h2>
            <%= Student.count %>
        </h2>

    </div>

    <div class="stat-card">

        <small>Avg Duration</small>

        <% avg_duration = @courses.any? ? (@courses.sum { |c| c.duration.to_i }.to_f / @courses.count).round(1) : 0 %>

          <h2>

              <%= avg_duration %> Years

          </h2>

    </div>

      <div class="stat-card">

        <small>Total Fees</small>

        <h2>

            ₹<%= number_with_delimiter(@courses.sum(:fees)) %>

        </h2>

      </div>

    </div>

    <div class="course-search">

      <i class="bi bi-search"></i>

      <input
          type="text"
          placeholder="Search Course..."
          id="courseSearch">

    </div>

    <div class="course-grid">

<% @courses.each do |course| %>

<%
colors = %w[
blue
green
purple
orange
red
teal
]

color = colors[course.id % colors.length]

filled = course.students.count
total = course.total_seats.to_i

seat_percentage =
  total.zero? ? 0 : ((filled.to_f / total) * 100).round

status =
  if seat_percentage >= 100
    "Full"
  elsif seat_percentage >= 85
    "Almost Full"
  elsif seat_percentage >= 60
    "Filling Fast"
  else
    "Open"
  end

progress_color =
  if seat_percentage >= 85
    "bg-danger"
  elsif seat_percentage >= 60
    "bg-warning"
  else
    "bg-success"
  end
%>

<div class="course-card">

    <div class="course-top">

        <div class="course-icon <%= color %>">

            <i class="bi bi-mortarboard-fill"></i>

        </div>

        <div class="course-title">

            <h3><%= course.course_code %></h3>

            <p><%= course.course_name %></p>

            <span class="course-status">

                <%= status %>

            </span>

        </div>

    </div>

    <div class="course-info">

        <div class="detail-row">

            <span>Duration</span>

            <strong><%= course.duration %> Years</strong>

        </div>

        <div class="detail-row">

            <span>Annual Fee</span>

            <strong>

                ₹<%= number_with_delimiter(course.fees) %>

            </strong>

        </div>

        <div class="detail-row">

            <span>Students</span>

            <strong>

                <%= filled %> / <%= total %>

            </strong>

        </div>

        <div class="detail-row">

            <span>Teachers</span>

            <strong>

                <%= course.teachers.count %>

            </strong>

        </div>

    </div>

    <div class="course-progress">

        <div class="progress-label">

            <span>Seat Occupancy</span>

            <strong>

                <%= seat_percentage %>%

            </strong>

        </div>

        <div class="progress">

            <div class="progress-bar <%= progress_color %>"

                 style="width:<%= seat_percentage %>%">

            </div>

        </div>

    </div>

    <div class="course-footer">

        <%= link_to edit_course_path(course),

            class:"btn btn-warning btn-sm" do %>

            <i class="bi bi-pencil"></i>

            Edit

        <% end %>

        <%= button_to course,

            method: :delete,

            form: {

              data: {

                turbo_confirm: "Delete this course?"

              }

            },

            class:"btn btn-danger btn-sm" do %>

            <i class="bi bi-trash"></i>

            Delete

        <% end %>

    </div>

</div>

<% end %>

</div>


</div>