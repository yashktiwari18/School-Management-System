<div class="overview-summary">

    <div class="summary-card blue">

        <div class="summary-top">

            <div class="summary-icon">
                <i class="bi bi-mortarboard-fill"></i>
            </div>

            <div class="summary-value">
                <%= @students_present %>
            </div>

        </div>

        <h4>Students Present</h4>

        <p>
            <%= @total_students %> Total Students
        </p>

    </div>



    <div class="summary-card green">

        <div class="summary-top">

            <div class="summary-icon">
                <i class="bi bi-mortarboard-fill"></i>
            </div>

            <div class="summary-value">
                <%= @teachers_present %>
            </div>

        </div>

        <h4>Students Present</h4>

        <p>
            <%= @total_teachers %> Total Teachers
        </p>

    </div>



    <div class="summary-card green">

        <div class="summary-top">

            <div class="summary-icon">
                <i class="bi bi-mortarboard-fill"></i>
            </div>

            <div class="summary-value">
                <%= @students_late %>
            </div>

        </div>

        <h4>Late Arrivals</h4>


    </div>



  <div class="summary-card orange">

      <div class="icon">
          ⏰
      </div>

      <div>

          <h4>Late Arrivals</h4>

          <h2>
              <%= @students_late %>
          </h2>

          <p>
              Students
          </p>

      </div>

  </div>



  <div class="summary-card purple">

      <div class="icon">
          📈
      </div>

      <div>

          <h4>Attendance Rate</h4>

          <h2>
              <%= @attendance_rate %>%
          </h2>

          <p>
              Today
          </p>

      </div>

  </div>

</div>


<div class="attendance-progress-card">

  <div class="card-title">
    <i class="bi bi-clipboard-check"></i>
    <h3>Today's Attendance Completion</h3>
  </div>

  <div class="progress-info">

    <span>
      <%= @completed_classes %> /
      <%= @total_classes %> Classes Submitted
    </span>

    <strong>
      <%= @completion_rate %>%
    </strong>

  </div>

  <div class="progress">

    <div class="progress-bar bg-success"
         style="width:<%= @completion_rate %>%">
    </div>

  </div>

</div>

<div class="overview-grid">

  <div class="overview-card">

      <div class="card-title">

          <i class="bi bi-mortarboard-fill"></i>

          <h4>Course Attendance</h4>

      </div>

      <% @courses.each do |course| %>

        <div class="info-row">

            <span>

                <%= course.course_code %>

            </span>

            <strong>

                92%

            </strong>

        </div>

      <% end %>

  </div>

  <div class="overview-card">

    <div class="card-title">

        <i class="bi bi-person-workspace"></i>

        <h4>Teacher Status</h4>

    </div>

    <% @teachers.each do |teacher| %>

      <div class="info-row">

          <span>

              <%= teacher.teacher_name %>

          </span>

          <span class="badge bg-success">

              Submitted

          </span>

      </div>

    <% end %>

</div>


<div class="overview-card full-width">

    <div class="card-title">

        <i class="bi bi-clock-history"></i>

        <h4>Recent Attendance Activity</h4>

    </div>

    <div class="activity-item">

        <strong>10:05 AM</strong>

        Teacher 1 submitted attendance for BCA.

    </div>

    <div class="activity-item">

        <strong>11:00 AM</strong>

        Teacher 2 submitted attendance for MBA.

    </div>

</div>