<div class="page-header">
  <div>
    <h2>Attendance Dashboard</h2>
    <p>Monitor today's attendance across the school.</p>
  </div>

  <div class="header-actions">
    <%= link_to "Mark Attendance",
        new_attendance_path,
        class: "btn btn-primary" %>

    <%= link_to "#",
        class: "btn btn-outline-primary" do %>
      Attendance Report
    <% end %>
  </div>
</div>


<!-- Today's Overview -->

<div class="dashboard-section">

    <h4>Today's Overview</h4>

    <div class="summary-grid">

        <div class="summary-card attendance-card">

    <div class="card-icon bg-primary">

        <i class="bi bi-mortarboard-fill"></i>

    </div>

    <div class="card-content">

        <h6>Students Present</h6>

        <h2>0 / 0</h2>

        <p>Today's student attendance</p>

    </div>

    <span class="trend-badge">

        Updated Today

    </span>

</div>

        <div class="summary-card">
            <h5>Teachers Present</h5>
            <h2>0 / 0</h2>
        </div>

        <div class="summary-card">
            <h5>Attendance Rate</h5>
            <h2>0%</h2>
        </div>

        <div class="summary-card">
            <h5>Late Arrivals</h5>
            <h2>0</h2>
        </div>

    </div>

</div>


<!-- Two Column Layout -->

<div class="dashboard-grid">

    <!-- Left Column -->

    <div class="dashboard-left">

        <div class="dashboard-card">

            <div class="section-header">
                <h4>Class-wise Attendance</h4>
            </div>

            <div class="table-responsive">

                <table class="table table-hover align-middle">

                    <thead>

                        <tr>
                            <th>Course</th>
                            <th>Total Students</th>
                            <th>Present</th>
                            <th>Absent</th>
                            <th>Attendance</th>
                            <th>Action</th>
                        </tr>

                    </thead>

                    <tbody>

                        <% @courses.each do |course| %>

                            <tr>

                                <td>
                                    <strong><%= course.course_name %></strong>
                                </td>

                                <td>
                                    <%= course.students.count %>
                                </td>

                                <td>0</td>

                                <td>0</td>

                                <td>
                                    <span class="badge bg-secondary">
                                        0%
                                    </span>
                                </td>

                                <td>

                                    <%= link_to "#",
                                        class: "btn btn-sm btn-outline-primary" do %>

                                        <i class="bi bi-eye"></i>
                                        View

                                    <% end %>

                                </td>

                            </tr>

                        <% end %>

                    </tbody>

                </table>

            </div>

        </div>

    </div>


    <!-- Right Column -->

    <div class="dashboard-right">

        <div class="dashboard-card">

            <h4>Teacher Attendance</h4>

            <div class="summary-grid teacher-summary">

                <div class="summary-card">
                    <h5>Total Teachers</h5>
                    <h2><%= Teacher.count %></h2>
                </div>

                <div class="summary-card">
                    <h5>Present</h5>
                    <h2>0</h2>
                </div>

                <div class="summary-card">
                    <h5>Absent</h5>
                    <h2>0</h2>
                </div>

                <div class="summary-card">
                    <h5>On Leave</h5>
                    <h2>0</h2>
                </div>

            </div>

            <div class="table-responsive mt-4">

                <table class="table table-hover align-middle">

                    <thead>

                        <tr>
                            <th>Teacher</th>
                            <th>Course</th>
                            <th>Status</th>
                        </tr>

                    </thead>

                    <tbody>

                        <% @teachers.each do |teacher| %>

                            <tr>

                                <td>
                                    <%= teacher.teacher_name %>
                                </td>

                                <td>
                                    <%= teacher.course.course_name %>
                                </td>

                                <td>

                                    <span class="badge bg-success">
                                        Present
                                    </span>

                                </td>

                            </tr>

                        <% end %>

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>