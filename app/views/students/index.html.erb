<div class="py-4">

  <div class="d-flex justify-content-between align-items-center mb-4">

    <h2>Student Management</h2>

    <%= link_to "Add Student",
                new_student_path,
                class: "btn btn-primary" %>

  </div>

  <% if @students.any? %>

    <table class="table table-bordered table-hover">

      <thead class="table-dark">

        <tr>
          <th>Name</th>
          <th>Email</th>
          <th>Phone</th>
          <th>Gender</th>
          <th>Course</th>
        </tr>

      </thead>

      <tbody>

  <% @students.each do |student| %>

    <tr>

      <td>
        <%= link_to student.student_name,
        student_path(student),
        class: "student-name-link" %>
      </td>
      <td><%= student.email %></td>
      <td><%= student.phone %></td>
      <td><%= student.gender %></td>

      <td>
        <%= student.course.course_name %>
      </td>
    </tr>

  <% end %>

</tbody>

    </table>

  <% else %>

    <div class="alert alert-info">
      No Student found. Click <strong>"Add Student"</strong> to create your first student.
    </div>

  <% end %>

</div>