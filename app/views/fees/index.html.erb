<div class="page-header">

    <div>

        <h2>Fee Management</h2>

        <p class="text-muted">
            Manage student fee collection and payment records.
        </p>

    </div>

    <%= link_to "Add Fee",
        new_fee_path,
        class: "btn btn-primary" %>

</div>

<div class="row g-4 mb-4">

  <!-- Total Collection -->

  <div class="col-lg-3 col-md-6">

    <div class="stats-card">

      <div class="stats-top">

        <div class="stats-icon fees">
          <i class="bi bi-wallet2"></i>
        </div>

      </div>

      <div class="stats-body">

        <h2>₹<%= @total_collection %></h2>

        <h6>Total Collection</h6>

        <p>Total fees assigned</p>

      </div>

    </div>

  </div>

  <!-- Paid -->

  <div class="col-lg-3 col-md-6">

    <div class="stats-card">

      <div class="stats-top">

        <div class="stats-icon teachers">
          <i class="bi bi-check-circle-fill"></i>
        </div>

      </div>

      <div class="stats-body">

        <h2>₹<%= @total_paid %></h2>

        <h6>Paid</h6>

        <p>Collected successfully</p>

      </div>

    </div>

  </div>

  <!-- Pending -->

  <div class="col-lg-3 col-md-6">

    <div class="stats-card">

      <div class="stats-top">

        <div class="stats-icon courses">
          <i class="bi bi-clock-history"></i>
        </div>

      </div>

      <div class="stats-body">

        <h2>₹<%= @total_pending %></h2>

        <h6>Pending</h6>

        <p>Awaiting payment</p>

      </div>

    </div>

  </div>

  <!-- Overdue -->

  <div class="col-lg-3 col-md-6">

    <div class="stats-card">

      <div class="stats-top">

        <div class="stats-icon students">
          <i class="bi bi-exclamation-triangle-fill"></i>
        </div>

      </div>

      <div class="stats-body">

        <h2><%= @overdue_count %></h2>

        <h6>Overdue</h6>

        <p>Need immediate attention</p>

      </div>

    </div>

  </div>

</div>

<div class="content-card">

    <div class="table-header">

  <div>
    <h4>Fee Records</h4>
    <p class="text-muted mb-0">
      View and manage all student fee payments.
    </p>
  </div>

  <div class="table-actions">

    <input
      type="text"
      class="form-control"
      placeholder="Search student...">

    <select class="form-select">
      <option>All Status</option>
      <option>Paid</option>
      <option>Pending</option>
      <option>Overdue</option>
    </select>

  </div>

</div>


<table class="table fee-table align-middle">

    <thead>

        <tr>

            <th>Student</th>
            <th>Course</th>
            <th>Total Fee</th>
            <th>Paid</th>
            <th>Due</th>
            <th>Status</th>
            <th width="180">Action</th>

        </tr>

    </thead>

    <tbody>

        <% @fees.each do |fee| %>

            <tr>

                <td>
                    <strong><%= fee.student.student_name %></strong>
                </td>

                <td>
                    <%= fee.student.course.course_name %>
                </td>

                <td>
                    ₹<%= fee.total_fee %>
                </td>

                <td>
                    ₹<%= fee.paid_fee %>
                </td>

                <td>
                    ₹<%= fee.due_fee %>
                </td>

                <td>

                    <span class="status-badge">
                        <%= fee.status %>
                    </span>

                </td>

                <td>

                    Edit | Delete

                </td>

            </tr>

        <% end %>

    </tbody>

</table>

</div>