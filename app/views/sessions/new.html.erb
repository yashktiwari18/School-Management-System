<h1>School Management System</h1>

<h2>Admin Login</h2>

<%= form_with url: login_path, local: true do |form| %>

  <div>
    <%= form.label :username %><br>
    <%= form.text_field :username %>
  </div>

  <br>

  <div>
    <%= form.label :password %><br>
    <%= form.password_field :password %>
  </div>

  <br>

  <%= form.submit "Login" %>

<% end %>