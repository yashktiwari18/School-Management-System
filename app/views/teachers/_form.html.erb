<%= form_with(model: @teacher, local: true) do |form| %>

  <% if @teacher.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% @teacher.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= form.label :teacher_name %>
    <%= form.text_field :teacher_name, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= form.label :email %>
    <%= form.email_field :email, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= form.label :phone %>
    <%= form.text_field :phone, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= form.label :gender %>
    <%= form.select :gender,
          ["Male", "Female", "Other"],
          { prompt: "Select Gender" },
          class: "form-select" %>
  </div>

  <div class="mb-3">
    <%= form.label :education %>
    <%= form.text_field :education, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= form.label :course %>

    <%= form.collection_select(
          :course_id,
          @courses,
          :id,
          :course_name,
          { prompt: "Select Course" },
          { class: "form-select" }
        ) %>
  </div>

  <%= form.submit(
        @teacher.new_record? ? "Create Teacher" : "Update Teacher",
        class: "btn btn-success"
      ) %>

  <%= link_to "Back", teachers_path, class: "btn btn-secondary" %>

<% end %>